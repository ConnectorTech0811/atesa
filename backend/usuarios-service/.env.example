# ============================================================
# Usuários Service - Configuração de ambiente
# ============================================================
PORT=3002
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3307
DB_USER=atesa
DB_PASSWORD=atesa
DB_NAME=usuarios_db

# Segredo do JWT - DEVE ser o mesmo valor configurado no gateway,
# pois é o gateway quem verifica o token nas rotas protegidas.
JWT_SECRET=troque-este-valor-em-producao
JWT_EXPIRES_IN=8h
