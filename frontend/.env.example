# ============================================================
# ATESA Frontend - Configuração de ambiente
# ============================================================
# Este arquivo define a identidade visual e a API de UMA empresa.
# Para replicar o sistema para outra empresa (white-label), copie
# este arquivo para .env e ajuste os valores abaixo com a marca
# e o backend daquela empresa. Cada empresa tem seu próprio
# frontend buildado/deployado com seu próprio .env.
# ============================================================

# URL da API do backend desta empresa
VITE_API_URL=http://localhost:3000/api

# Nome da aplicação (usado no título da aba e em telas internas)
VITE_APP_NAME=ATESA

# Identidade visual (cores da marca)
VITE_BRAND_PRIMARY_COLOR=#4a9e4f
VITE_BRAND_PRIMARY_DARK=#3a7e3f
VITE_BRAND_PRIMARY_LIGHT=#6bbf71
VITE_BRAND_SECONDARY_COLOR=#7a7a7a
VITE_BRAND_BACKGROUND=#f2f2f2

# Logo exibido no login e no menu lateral (caminho dentro de /public)
VITE_BRAND_LOGO=/atesa_logo.png
